# ── YT Shorts Factory Configuration ──────────────────────
# Copy this file to .env and customize for your system.
# Developed by Abrar Hussain

# ── Whisper AI ──────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_LANGUAGE=auto
WHISPER_TASK=transcribe
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_BEAM_SIZE=5

# ── Clip Duration ──────────────────────────────────────
# Presets: quick(25s) / standard(45s) / extended(180s)
# Also accepts: 25s, 45s, 3min
CLIP_DURATION_PRESET=standard

# ── Channel Branding ───────────────────────────────────
CHANNEL_NAME=
CHANNEL_PATTERN=

# ── Channel Logo ───────────────────────────────────────
LOGO_PATH=assets/logo.png
LOGO_POSITION=top-right
LOGO_OPACITY=0.85
LOGO_SCALE=0.12
LOGO_FADE_DURATION=1.0
LOGO_MARGIN=20

# ── FFmpeg ─────────────────────────────────────────────
FFMPEG_PRESET=fast
FFMPEG_CRF=23
FFMPEG_AUDIO_BITRATE=192k
FFMPEG_VIDEO_CODEC=libx264
FFMPEG_AUDIO_CODEC=aac
FFMPEG_PIXEL_FORMAT=yuv420p
FFMPEG_THREADS=0
FFMPEG_HW_ACCEL=auto

# ── GPU (uncomment if you have NVIDIA GPU) ─────────────
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16
# FFMPEG_HW_ACCEL=nvenc
# FFMPEG_VIDEO_CODEC=h264_nvenc

# ── Speed Optimizations ────────────────────────────────
SPEED_PARALLEL_EXPORT=true
SPEED_USE_FASTER_WHISPER=true
SPEED_AUTO_HW_ACCEL=true
SPEED_OPTIMAL_THREADS=true

# ── Platform Exports ───────────────────────────────────
EXPORT_YOUTUBE=true
EXPORT_TIKTOK=true
EXPORT_REELS=true

# ── Subtitles ──────────────────────────────────────────
SUBTITLE_ANIMATION=karaoke
SUBTITLE_FONT=Arial Black
SUBTITLE_FONT_SIZE=22
